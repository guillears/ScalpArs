container_commands:
  01_create_data_dir:
    command: "mkdir -p /opt/scalpars-data"
    leader_only: true
  02_link_db:
    command: "ln -sf /opt/scalpars-data/scalpars.db /var/app/staging/scalpars.db"
    leader_only: true
  03_copy_config:
    command: "test -f /opt/scalpars-data/trading_config.json && ln -sf /opt/scalpars-data/trading_config.json /var/app/staging/trading_config.json || cp /var/app/staging/trading_config.json /opt/scalpars-data/trading_config.json"
    leader_only: true
